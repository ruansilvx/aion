# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
.env
.aider*

# Android signing
**/android/key.properties
**/android/app/*.jks
**/android/app/*.keystore

# iOS signing / provisioning
**/ios/Runner.xcarchive
*.mobileprovision
*.p12

# Firebase / backend credentials
**/android/app/google-services.json
**/ios/Runner/GoogleService-Info.plist

*.g.dart

# Generated localization output (flutter gen-l10n, see l10n.yaml)
lib/l10n/generated/

# CocoaPods (iOS/macOS)
**/Pods/
**/.symlinks/
**/*.xcworkspace

# Ephemeral platform files (regenerated by `flutter create`)
**/macos/Flutter/ephemeral/
**/macos/Flutter/Flutter-Generated.xcconfig
**/windows/flutter/ephemeral/
**/linux/flutter/ephemeral/

# Web
/web/sqlite3.wasm

# Local MCP server config
.mcp.json

# Local Claude Code config (permissions, dev-server launch config) —
# kept on disk for convenience, never committed. Skills/CLAUDE.md live
# in ~/.claude/skills/ and openspec/CLAUDE.md instead.
.claude/

# agent_bridge/ Node dependencies — fetched via `npm install`, see
# aion-arch/changes/provider-configuration/proposal.md's Non-goals.
agent_bridge/node_modules/

# Aion's own project-bookkeeping data, written by the app itself when
# this checkout is registered as an Aion "project" root for dogfooding
# self-iteration (ticket git-projection has no separate storage target
# yet — see aion-arch/ideas/self-iteration-sequencing.md). Never part
# of the app's own source.
.aion/
tickets/